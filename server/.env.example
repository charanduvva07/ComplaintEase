# ─────────────────────────────────────────────────────────────
# ComplaintEase – Server Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────

# Node Environment: development | production
NODE_ENV=development

# Server Port
PORT=5000

# ─── Database ────────────────────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/complaintease

# MongoDB Atlas (uncomment for production)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/complaintease?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRE=7d
RESET_TOKEN_EXPIRE=10

# ─── Client URL ──────────────────────────────────────────────
# Development
CLIENT_URL=http://localhost:5173
# Production (your Vercel frontend URL)
# CLIENT_URL=https://complaintease.vercel.app

# ─── Email (Nodemailer) ───────────────────────────────────────
# Gmail: Use App Passwords (enable 2FA + generate App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=ComplaintEase <noreply@complaintease.com>

# ─── Cloudinary (File Uploads) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=complaintease

# ─── Rate Limiting ────────────────────────────────────────────
# General API limit
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=200

# ─── Optional: Error Tracking ─────────────────────────────────
# SENTRY_DSN=https://your_sentry_dsn
